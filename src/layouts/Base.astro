---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Rod Woods · Field Notes" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <style is:global>
      :root {
        --bg: #ffffff; --fg: #1c2733; --muted: #5a6a7a; --accent: #b4552d;
        --border: #e3e8ee; --code-bg: #f4f6f8;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #12161b; --fg: #d8dee6; --muted: #8b98a7; --accent: #e0764a;
          --border: #26303b; --code-bg: #1b222b;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 17px/1.65 Georgia, 'Times New Roman', serif;
      }
      header.site, main, footer.site {
        max-width: 42rem; margin: 0 auto; padding: 0 1.2rem;
      }
      header.site {
        display: flex; justify-content: space-between; align-items: baseline;
        padding-top: 1.6rem; padding-bottom: 0.4rem;
        font-family: system-ui, sans-serif;
      }
      header.site a { color: var(--fg); text-decoration: none; font-weight: 700; }
      header.site nav a { color: var(--muted); font-weight: 400; margin-left: 1rem; font-size: 0.95rem; }
      header.site nav a:hover { color: var(--accent); }
      main { padding-bottom: 3rem; }
      h1, h2, h3 { font-family: system-ui, sans-serif; line-height: 1.25; }
      h1 { font-size: 1.7rem; margin: 2rem 0 0.4rem; }
      h2 { font-size: 1.25rem; margin-top: 2.2rem; }
      a { color: var(--accent); }
      .meta { color: var(--muted); font-size: 0.9rem; font-family: system-ui, sans-serif; }
      table { border-collapse: collapse; width: 100%; font-size: 0.92rem; font-family: system-ui, sans-serif; display: block; overflow-x: auto; }
      th, td { border: 1px solid var(--border); padding: 6px 10px; text-align: left; }
      code { background: var(--code-bg); padding: 1px 5px; border-radius: 3px; font-size: 0.88em; }
      pre { background: var(--code-bg); padding: 12px; border-radius: 6px; overflow-x: auto; }
      pre code { background: none; padding: 0; }
      blockquote { border-left: 3px solid var(--border); margin-left: 0; padding-left: 1rem; color: var(--muted); }
      hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
      footer.site {
        border-top: 1px solid var(--border); padding-top: 1rem; padding-bottom: 2.5rem;
        color: var(--muted); font-size: 0.88rem; font-family: system-ui, sans-serif;
      }
      ul.postlist { list-style: none; padding: 0; }
      ul.postlist li { margin-bottom: 1.4rem; }
      ul.postlist .title { font-family: system-ui, sans-serif; font-weight: 600; font-size: 1.1rem; }
    </style>
  </head>
  <body>
    <header class="site">
      <a href="/">Rod Woods · Field Notes</a>
      <nav>
        <a href="/about/">About</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      Rodney Woods · offline speech and language AI on consumer hardware ·
      <a href="https://github.com/Rodder5">GitHub</a> ·
      <a href="https://www.linkedin.com/in/rodney-woods-85bba52ab">LinkedIn</a>
    </footer>
  </body>
</html>
